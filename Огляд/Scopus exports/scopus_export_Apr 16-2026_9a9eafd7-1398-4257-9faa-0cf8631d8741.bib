}

@ARTICLE{Gu2015143,
	author = {Gu, Xiaoqing and Chen, Shan and Zhu, Wenbo and Lin, Lin},
	title = {An intervention framework designed to develop the collaborative problem-solving skills of primary school students},
	year = {2015},
	journal = {Educational Technology Research and Development},
	volume = {63},
	number = {1},
