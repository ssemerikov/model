	note = {Cited by: 0}
}

@ARTICLE{Klein2000,
	author = {Klein, Evelyn R. and Hammrich, Penny L. and Bloom, Stefanie and Ragins, Anika},
	title = {Language development and science inquiry: The head start on science and communication program},
	year = {2000},
	journal = {Early Childhood Research and Practice},
	volume = {2},
	number = {2},
	pages = {},
	url = {https://www.scopus.com/pages/publications/3042599692?origin=resultslist},
	abstract = {There are ongoing discussions about the best way to teach science to young children during the preschool and early elementary school years. What practice is most likely to contribute to children's development and learning while cultivating exploration, questioning skills, and revision of thinking to accommodate new ideas in science? The Head Start on Science and Communication (HSSC) Program is based on collaborative research from the fields of science education and language development. Program objectives have been aligned with the curriculum and are based on the national science standards for young children. The HSSC Program evolved over four years of research and implementation at schools in Pennsylvania, New Jersey, and Washington, DC. The initial phase of the program included input from parents, teachers, and teaching assistants to help develop lessons and shape the inquiry-based strategies for young children learning about life science, earth science, and physical science. The second phase of the program incorporated curriculum materials and investigative experiments to promote inquiry-based, hands-on science as a vehicle for promoting young children's language development. Children learned to match, discriminate, categorize, sequence, and associate information as they worked with peers to understand science concepts, relate facts, and solve scientific problems. As a result of participating in the HSSC Program, teachers employed collaborative learning strategies, engaging in small-group problem-solving teams with verbal interactions among teachers and students. Outcomes also included positive changes in teachers' questioning strategies. Teachers became proficient in asking more open-ended questions at increasing levels of difficulty instead of basic factual and yes-no questions. Preliminary data from a study of 85 first-grade students who engaged in a series of 12 science experiments indicated that prior to the program, they answered an average of 58% of the factual-type questions correctly and 15% of the application-type questions correctly. After learning about topics such as earth surfaces, minerals, changing colors, seeds, and plants, these children answered the factual-type questions with 96% accuracy and the application-type questions with 92% accuracy, indicating a significant gain in knowledge beyond the p < .05 level for both types of questions. Students improved their knowledge of science concepts along with their ability to answer questions requiring higher-level cognitive skills. Teachers noted students' improved knowledge of science and enhanced language development.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 17}
}

@BOOK{Vick2017199,
	author = {Vick, Matthew E. and Reichhoff, Nicholas F.},
	title = {COLLABORATIVE PARTNERSHIPS BETWEEN PRESERVICE AND INSERVICE TEACHERS AS A DRIVER FOR PROFESSIONAL DEVELOPMENT},
	year = {2017},
	journal = {Exploring the Community Impact of Research–Practice Partnerships in Education},
	pages = {199 - 224},
	doi = {10.1108/978-1-68123-830-220251012},
	url = {https://www.scopus.com/pages/publications/105029194277?origin=resultslist},
	abstract = {This chapter describes and analyzes the results of a science methods course for elementary teachers that was conducted at a local elementary school in the “third space” of teacher education. Preservice teachers benefited from learning both academic knowledge from the university instructors and practical knowledge from inservice teachers. The embedded nature of the course reduced the traditional hierarchy that privileges academic knowledge in university classrooms and practical knowledge in PK–12 classrooms. Inservice teachers were collaborative partners in the course, serving as informal mentors/coaches for the preservice teachers. Our exploratory results indicate that inservice teachers benefited from this interaction as did the preservice teachers. A third space course thus also becomes an example of Bredeson’s “professional development in work” as opposed to something done outside of work for inservice teachers. Rather than the professional development schools model where university faculty provide extensive professional development to inservice teachers, this methods course offered inservice teachers the opportunity to develop new knowledge and dispositions toward inquirybased teaching and engineering design processes as a result of their collaboration with preservice teachers. Naturalistic inquiry with analytic induction and document analysis of lesson plans through the lens of Webb’s Depth of Knowledge (DOK) framework were used to reveal the themes that inservice teachers uncovered through their work with their partnership. © 2017 Information Age Publishing Inc. All rights reserved.},
	keywords = {Collaborative learning; Curricula; Employment; Engineering education; Teaching; Collaborative partnerships; Elementary schools; Elementary teachers; Preservice teachers; Professional development; Science methods; Teacher education; Teachers'; Third spaces; University classrooms; Professional aspects},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@CONFERENCE{Maxwell2013,
	author = {Maxwell, Andrew and Fogarty, Roderick and Gibbings, Peter and Noble, Karen and Kist, Alexander A. and Midgley, Warren},
	title = {Robot RAL-ly international - Promoting STEM in elementary school across international boundaries using remote access technology},
	year = {2013},
	journal = {2013 10th International Conference on Remote Engineering and Virtual Instrumentation, REV 2013},
	pages = {},
	doi = {10.1109/REV.2013.6502895},
	url = {https://www.scopus.com/pages/publications/84877682041?origin=resultslist},
	abstract = {Engaging school children early in STEM activities plays an important role in their choice to study engineering in later years. This paper describes a pilot project where Remote Access Laboratory technology at a university is employed in an inquiry-based learning activity with elementary school children in Japan and Australia. Investigation into how RAL technology facilitated collaborative learning in the K-12 demographic was then examined. Children in Japan designed a track that was constructed by their peers in Australia. The Japanese students then navigated the track in Australia with remotely controlled robots using the RAL system. A number of camera feeds allowed the students to observe the robots and the track. Both groups of students, as well as the participant researchers, took part in co-constructed focus group discussions after the event. A thematic analysis indicates that these activities provide students with opportunities for rich learning experiences in science, math and technology. Engaging young children in STEM activities provides a strong pathway to a better understanding of science concepts and ultimately a career in engineering. © 2013 IEEE.},
	author_keywords = {remote access laboratory; STEM},
	keywords = {Professional aspects; Robots; Students; Technology; Collaborative learning; Elementary schools; Inquiry-based learning; Remote access laboratories; Rich learning experiences; STEM; STEM activities; Thematic analysis; Engineering education},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 15}
