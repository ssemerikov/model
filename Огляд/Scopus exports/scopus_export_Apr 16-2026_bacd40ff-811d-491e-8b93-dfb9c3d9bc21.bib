@ARTICLE{Canipe202660,
	author = {Canipe, Martha M. and Gray, Ron E.},
	title = {Scaffolding Visual Representation in Modeling Practices for University Science Instructors},
	year = {2026},
	journal = {Journal of College Science Teaching},
	volume = {55},
	number = {1},
	pages = {60 - 68},
	doi = {10.1080/0047231X.2025.2571721},
	url = {https://www.scopus.com/pages/publications/105019324727?origin=resultslist},
	abstract = {This study explores how undergraduate preservice elementary teacher students engage with visual representation tools while developing explanatory models in a science course heavily focused on the practice of scientific modeling. Framed within sociocultural theory, the research emphasizes that learning is mediated through social interactions and cultural tools, including visual representations. Through analysis of models produced by students in a two-semester science content course, the study found that students often defaulted to familiar but less effective methods, such as text-heavy explanations, when creating models. However, students also incorporated more complex visual tools like arrows, zoom-in windows, and cut-aways to some extent. These tools helped students better capture the relationships, processes, and scales relevant to the scientific phenomena they were modeling. The findings underscore the importance of scaffolding as a way to support students in mastering the use of culturally significant visual tools for scientific modeling. The study concludes with implications for science educators, suggesting that integrating structured scaffolding into university-level science courses can help students internalize the use of visual tools, thereby enhancing their ability to construct and communicate scientific understanding. © 2025 National Science Teaching Association.},
	author_keywords = {Modeling; Representations; Science practices},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Vu202624,
	author = {Vu, Dinh-Minh and Le, Hieu-Hoc and Tan, Phan Xuan and Tu, Nguyen Thi Thanh},
	title = {Personalized and Scalable Problem-Based Learning in Soft Skills Education: The Role of AI Agents in Multidisciplinary Contexts},
	year = {2026},
	journal = {International Journal of Engineering Pedagogy},
	volume = {16},
	number = {1},
	pages = {24 - 43},
	doi = {10.3991/ijep.v16i1.57581},
	url = {https://www.scopus.com/pages/publications/105032996628?origin=resultslist},
	abstract = {Soft skills development remains a critical challenge in higher education, especially in large, multidisciplinary learning environments where students vary in background, motivation, and self-regulatory capacity. Although problem-based learning (PBL) is broadly acknowledged as a successful method for developing critical skills and abilities such as planning, collaboration, and reflective thinking, traditional implementations often face constraints in personalization, coordination, and formative assessment. This study introduces an enhanced PBL model augmented by artificial intelligence (AI) Agents to support soft skills acquisition in blended learning contexts. The AI Agent, leveraging natural language processing (NLP) and automation via the n8n platform, functioned as a virtual assistant to facilitate task planning, peer coordination, self-monitoring, and timely feedback. A quasi-experimental study was carried out involving three groups of students (N=263) participating in a course focused on developing soft skills, comprising one group using AI-supported PBL, another group using traditional PBL, and a control group taught through standard instructional methods. A mixed-methods analysis demonstrated that the group utilizing AI support exhibited statistically notable enhancements in their outcomes across six soft skill domains, particularly in planning, group work, and reflective learning (p < 0.001). Behavioral data from LMS logs and product assessments further validated enhanced collaboration, consistency, and accuracy in self-assessment among AI-supported learners. The findings demonstrate that integrating AI Agents into PBL not only reduces instructor workload and enhances instructional equity but also empowers learners through personalized, data-driven scaffolding. This approach offers promising implications for scalable, technology-enhanced soft skills education across disciplines. © 2026 by the authors.},
	author_keywords = {artificial intelligence (AI) agent; blended learning; problem-based learning (PBLpersonalization; soft skills},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access}
}

@ARTICLE{Gong2026311,
	author = {Gong, Yulin and Wang, Minkai and He, Li and Xu, Chengshu and Yu, Yue},
	title = {Asking, Playing, Learning: Investigating Large Language Model-Based Scaffolding in Digital Game-Based Learning for Elementary Artificial Intelligence Education},
	year = {2026},
	journal = {Journal of Educational Computing Research},
	volume = {64},
	number = {2},
	pages = {311 - 343},
	doi = {10.1177/07356331251396354},
	url = {https://www.scopus.com/pages/publications/105022013091?origin=resultslist},
	abstract = {Digital game-based learning (DGBL) has demonstrated notable effectiveness in general artificial intelligence (AI) literacy education, but it often falls short in addressing personalized learning needs. Traditional game-based scaffolding lacks real-time feedback, thereby limiting the students’ deep cognitive engagement. To address these limitations, this study introduces a large language model (LLM)-based scaffolding designed to create an engaging and interactive AI learning environment. Using a quasi-experimental design with fifth-grade students, we compared an experimental group using LLM-based scaffolding (LLM-DGBL) with a control group using traditional scaffolding (TS-DGBL). The results showed that the experimental group outperformed the control group in both learning achievement and cognitive load reduction. Behavioral analysis showed that students in the experimental group engaged in more diverse and deeper self-regulated learning patterns. Moreover, interaction analysis revealed a key pattern: students with a higher cognitive load sought support from the LLM-based scaffolding more frequently than their peers with a lower cognitive load. This study presents a novel method for elementary AI literacy education. It also provides a valuable reference for applying generative AI in educational practice to support the development of adaptive learning tools tailored for young learners. © The Author(s) 2025},
	author_keywords = {artificial intelligence education; digital game-based learning; large language model; large language model-based scaffolding},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1}
}

@ARTICLE{Sururuddin2026,
	author = {Sururuddin, Muhammad and Lasmawan, I Wayan and Arnyana, Ida Bagus Putu and Gede Margunayasa, I.},
	title = {Development and effectiveness of metacognitive-oriented integrated science-social learning devices (MOSSLDs) towards elementary student critical thinking abilities and learning outcomes},
	year = {2026},
	journal = {Multidisciplinary Science Journal},
	volume = {8},
	number = {5},
	pages = {},
	doi = {10.31893/multiscience.2026279},
	url = {https://www.scopus.com/pages/publications/105019976809?origin=resultslist},
	abstract = {Integrated Science-Social Studies learning at the elementary level often does not provide opportunities for reflective thinking, thus prompting this study to design and evaluate the Learning Tool with Metacognitive Orientation (MOSSLDS), aiming to improve students’ critical thinking skills and learning outcomes. Using an ADDIE-based Research and Development framework, researchers designed thematic modules, student worksheets, and lesson plans embedded with metacognitive scaffolds to support teaching and learning. These materials were implemented and evaluated through a quasi-experimental non-equivalent control group pre- and post-test design involving 75 students and 14 teachers in East Lombok, Indonesia. Findings revealed that Metacognitive-Oriented integrated Science-Social Learning Devices (MOSSLDs) were successfully developed, and students exposed to MOSSLDs exhibited significant improvements in critical thinking and learning outcomes. Expert validation yielded high validity scores (mean > 85%) and usability assessments rated the devices as very usable by teachers (4.37-4.55) and usable to very usable by students (3.86-4.57). Inferential analyses demonstrated significant improvements in both learning outcomes and critical thinking (normalized gains of 0.78 and 0.73, t-tests p <. 001) with very large effect sizes (Cohen’s d > 4.0). In addition, MOSSLDs show that metacognitive-based learning can be applied to various learning devices such as thematic modules, lesson plans, and student worksheets. These findings indicate that MOSSLDS effectively fosters critical thinking skills and academic performance, suggesting that integrating explicit metacognitive scaffolding into elementary interdisciplinary curricula can cultivate independent, reflective learners capable of addressing complex real-world challenges. © 2025, Malque Publishing. All rights reserved.},
	author_keywords = {critical thinking abilities; integrated science-social learning; learning devices; learning outcomes; metacognitive-oriented learning},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1; All Open Access; Gold Open Access}
}

@ARTICLE{Zhang2026,
	author = {Zhang, Chao and Gao, Qianqian and Wei, Yantao and Tong, Mingwen},
	title = {Enhancing elementary students’ question-asking skills with the KWLQ strategy in blended synchronous classrooms},
	year = {2026},
	journal = {Research in Science and Technological Education},
	pages = {},
	doi = {10.1080/02635143.2025.2611967},
	url = {https://www.scopus.com/pages/publications/105026608118?origin=resultslist},
	abstract = {Aim and background: Blended synchronous classrooms (BSC) enable real-time connections between local and remote students, promoting equitable science education. However, remote learners often show lower engagement and weaker inquiry participation, leading to poorer outcomes. As question-asking skills (QAS) are vital for scientific inquiry and higher-order thinking, enhancing QAS can help address these challenges. This study examines whether the know-want to know-learned-more questions (KWLQ) strategy can systematically improve remote students’ QAS in elementary science BSC. Sample and method: The study involved 110 remote students from two rural Chinese elementary schools, two intact remote classes were assigned to the experimental condition (KWLQ-based instruction, n = 55) and the control condition (inquiry-based instruction, n = 55). The intervention spanned 10 lessons on the ‘Sound’ unit. QAS was evaluated through pre- and post-tests across three dimensions: quantity, quality, and expression. Quantitative data were analyzed using independent and paired t-tests, while thematic analysis of semi-structured interviews with teachers and students provided qualitative insights into the mechanisms supporting QAS development in BSC. Result and discussion: Findings showed that the experimental group, which received KWLQ-based instruction, demonstrated si gnificantly greater overall improvement in QAS than the control group. Notably, the experimental group showed marked gains in the quality of questions asked and the total QAS score, while there was no significant difference in the number of questions or the quality of question expression between groups. Within-group comparisons revealed that only the experimental group exhibited significant pre- to post-test gains across QAS, whereas the control group showed minimal change. Findings also revealed that students perceived the KWLQ scaffolding as a critical mechanism for shifting from passive reception to active inquiry. Teachers further noted that the structured prompts, particularly in the W and Q phase, significantly enhanced students’ initiative in articulating curiosity and metacognitive reflection, although improvements in linguistic precision remained limited. © 2026 Informa UK Limited, trading as Taylor & Francis Group.},
	author_keywords = {blended synchronous classrooms; educational equity; elementary science; KWLQ strategy; question-asking skills},
	type = {Article},
	publication_stage = {Article in press},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Su2026,
	author = {Su, Chien-Yuan},
	title = {Integrating Metacognitive Scaffolding into a Physics Simulation for Elementary School Students’ Conceptual Understanding of Force and Motion},
	year = {2026},
	journal = {Journal of Science Education and Technology},
	pages = {},
	doi = {10.1007/s10956-025-10288-z},
	url = {https://www.scopus.com/pages/publications/105026703046?origin=resultslist},
	abstract = {The incorporation of metacognitive scaffolding into science education may foster self-regulated learning, potentially leading to significant improvements in student outcomes. Accordingly, this study investigates the effects of embedding metacognitive scaffolding within a PhET (Physics Education Technology) interactive simulation to enhance elementary school students’ conceptual understanding of force and motion. Fifty-four sixth-grade students from two classes were randomly allocated to either an experimental group which engaged with a physics simulation augmented by computer-based metacognitive scaffolding, or a control group which used the same simulation without scaffolding. Results revealed that the experimental group exhibited significantly greater improvements in scientific understanding and enhanced metacognitive skills in Planning, Monitoring, and Evaluation (PME) compared to the control group. However, no significant differences were observed in other metacognitive dimensions. Notably, the scaffolding intervention proved particularly beneficial for students with lower academic performance, underscoring its potential to support learning in physics simulations. These findings suggest that integrating metacognitive scaffolding into interactive simulations can effectively enhance conceptual understanding and support science learning in elementary education. © The Author(s), under exclusive licence to Springer Nature B.V. 2026.},
	author_keywords = {Conceptual understanding; Metacognitive scaffolding; Metacognitive skills on science; Physics simulation},
	type = {Article},
	publication_stage = {Article in press},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Jin2026,
	author = {Jin, Qingna},
	title = {Critical minds for a warming planet: a case study of children’s socioscientific reasoning (SSR) and critical information literacy (CIL) in climate change education},
	year = {2026},
	journal = {International Journal of Science Education},
	pages = {},
	doi = {10.1080/09500693.2026.2623673},
	url = {https://www.scopus.com/pages/publications/105029378572?origin=resultslist},
	abstract = {In an era of climate disruption and digital misinformation, developing students’ capacity to critically evaluate sources and communicate persuasively about socioscientific issues (SSI) is increasingly essential. This qualitative case study explores how Grade 5 students assess the credibility of climate change information and construct persuasive arguments. Grounded in critical information literacy (CIL) and socioscientific reasoning (SSR) frameworks, the study involved 36 students in eastern Canada who participated in interactive interviews, including ranking source credibility and selecting evidence to persuade a peer. Findings show that students consistently trusted scientific and educational authorities (e.g. NASA, teachers), valued traceable sources, and expressed scepticism toward open platforms such as YouTube. Their reasoning reflected emerging CIL, with attention to authorial intent and evidence quality. When constructing arguments, students combined personal narratives with empirical data, demonstrating audience-aware communication, which are hallmarks of SSR. These results suggest that with explicit scaffolding, elementary students can engage in complex evaluative and rhetorical reasoning. The study underscores the importance of integrating CIL and SSR into climate change and science education to foster digital discernment, ethical reflection, and civic agency from an early age. © 2026 Informa UK Limited, trading as Taylor & Francis Group.},
	author_keywords = {Climate change education; critical information literacy; socioscientific reasoning},
	type = {Article},
	publication_stage = {Article in press},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{El Ayat2026,
	author = {El Ayat, Nisrine and Boutalline, Mohammed and Tannouche, Adil and Ouazri, Chaimae and Yahyaoui, Mohammed},
	title = {Dynamic-rag: a multimodal emotion-aware prompting and retrieval-augmented LLM framework for autism support in adaptive learning systems},
	year = {2026},
	journal = {Quality and Quantity},
	pages = {},
	doi = {10.1007/s11135-026-02715-z},
	url = {https://www.scopus.com/pages/publications/105034697633?origin=resultslist},
	abstract = {Educational AI systems increasingly rely on generative models for personalization, yet most remain blind to learners’ emotional and cognitive states during instruction. This limitation particularly affects neurodivergent learners, including those with autism, whose performance depends heavily on emotional stability and appropriately calibrated instructional support. Current systems optimize for semantic accuracy but fail to adapt content complexity or pacing to individual readiness. To address this gap, we introduce DYNAMIC-RAG, a retrieval-augmented generation framework that integrates real-time learner-state modeling into adaptive tutoring. The system combines behavioral engagement, emotional valence-arousal, and clinical indicators into a unified Pedagogical Readiness Score (PRS) that drives coordinated adaptation across retrieval and generation. The PRS governs three adaptive mechanisms: retrieval depth (3–7 documents), content complexity (conceptual density), and generation parameters (response determinism vs. flexibility). Low-readiness learners receive scaffolded, simplified explanations with increased retrieval support; high-readiness learners access concise, abstract content promoting independent reasoning. Proof-of-concept evaluation with elementary mathematics (grades 3–5, n=40 queries) demonstrated meaningful improvements: exact match accuracy increased 17.5 percentage points (47.5% to 65.0%) compared to baseline LLM, with adaptive scaffolding benefiting low-readiness learners most substantially (+28.6 pp vs. +9.1 pp for high-readiness learners). Hallucination rates decreased 68% while maintaining real-time responsiveness (sub-2 s latency). These exploratory findings suggest that jointly adapting retrieval and generation based on learner state provides complementary benefits for factual accuracy and pedagogical appropriateness, though confirmatory validation across broader domains and populations remains necessary before large-scale deployment. © The Author(s), under exclusive licence to Springer Nature B.V. 2026.},
	author_keywords = {Affective computing; Autism spectrum disorder (ASD); Large language models (LLM); Multimodal learning analytics; Personalized tutoring; Retrieval-augmented generation (RAG)},
	type = {Article},
	publication_stage = {Article in press},
	source = {Scopus},
	note = {Cited by: 0}
}

