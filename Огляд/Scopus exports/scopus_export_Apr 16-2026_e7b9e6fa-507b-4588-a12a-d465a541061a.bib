@ARTICLE{Demetriou2021,
	author = {Demetriou, Andreas and Liakos, Antonis and Kizilyürek, Niyazi},
	title = {How wisdom emerges from intellectual development: A developmental/historical theory for raising mandelas},
	year = {2021},
	journal = {Journal of Intelligence},
	volume = {9},
