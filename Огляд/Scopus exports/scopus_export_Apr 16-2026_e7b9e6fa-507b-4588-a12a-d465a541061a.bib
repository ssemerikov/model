@BOOK{Sharma2015205,
	author = {Sharma, Charru},
	title = {Conclusion},
	year = {2015},
	journal = {Drama and Theatre with Children: International perspectives},
	pages = {205 - 208},
	doi = {10.4324/9781315716985-30},
	url = {https://www.scopus.com/pages/publications/85107243387?origin=resultslist},
	abstract = {This book supports the voices of drama and theatre teachers and practitioners in emphasizing that both drama and theatre are tools that enhance the development of children. In a drama class, children are creatively engaged in the learning process which stimulates them to think critically as active learners. As students participate in drama, they are challenged to take up different characters in a variety of situations. Children get an opportunity to explore the depths of characters through their own experiences, knowledge and learning. Learning that engages children potentially creates ‘thinking citizens’ for the future who can work towards creating a better world. It is interesting how the book unveils experiences of drama and theatre teachers, researchers and practitioners situated in different parts of the world, yet resonate similar voices through their work and experience. In her chapter, Aud Berggraf Sæbø described her project based on integrating process drama to develop students’ reading comprehension. As we read through her chapter, we learned how drama is placed in Norwegian schools and it was fascinating to hear how a language class can be brought alive by process drama. Within my chapter, I deliberated on the education reality in contemporary India and discussed the relevance of creative drama in the development of primary school children. The chapter was based on qualitative research, spread over two years and six months. In the chapter, I described the journey of a child blossoming as a creative individual as she participated in the creative drama workshops. I posited that teachers should be trained to integrate creative drama in the pedagogical exchange in primary classrooms to enrich the classroom culture. Making learning an active venture was the focus of Marie Jeanne McNaughton’s chapter, in which she presented drama in the Scottish curriculum. She also presented her work with BEd Drama Specialist students using three dramas. The Scottish Storyline approach and its links with drama were clearly visible in the chapter. In Helen Hallissey’s personal tales as an Irish primary school teacher, the readers got a glimpse of how drama is placed in the educational reality of different countries. The book also gives us the opportunity to evaluate drama in the New Zealand curriculum, as Janinka Greenwood walked us through the cultural diversity of the country. As she engaged in a classroom project employing drama in New Zealand primary schools, Greenwood commented on the expectations of the curriculum and its relationship with drama. The impact of emotions and the use of drama to teach how to deal with emotions was well etched by Aundraea Stevens. Her exploratory research projected the ability model of emotional intelligence in drama based on her work in Australia. Joanne O’Mara also talked about drama education in Australia, with her chapter approaching the vital dimension of teaching process drama to pre-service teachers based on interviews with drama practitioners. She also discussed the classroom strategies used by drama teachers. And Tiina Moore described the creation of the History Centre in Australian primary education, based on Dorothy Heathcote’s model of Mantle of the Expert. Mary-Rose McLaren shared the challenges and concerns of a drama teacher in an Australian school as the children engaged in creating a musical. Her experiences as an arts educator gives voice to drama teachers around the globe. Another engaging contribution for the book was by Lizette Stevenson, who described a drama project carried out with middle-school children in Queensland, Australia. She employed process drama and Mantle of the Expert to conclude that drama is an effective mode for learning science in a middleschool classroom as it is engaging, empowering and an active inquiry-based approach. Some of the other chapters discussed the theoretical constructs related to drama and the implications when used with children. Brian Woolland described the importance of creativity and how process drama unifies the aesthetic, social and pedagogical dimensions. Exploration, imagination and observation have been emphasized by Woolland and also by İsmail Güven and Ömer Adıgüzel in their contribution. Their chapter focused on developing social skills in children through creative drama. In Part II, we reached Brian Lighthill’s chapter, based in a school in England, in which he picked up Shakespeare’s stories and showed ways to help children unfold the layers beneath the obvious drama. Lighthill showed the interrelation of subjects like history, sociology, politics and literature, etc. within a pure literary text, which is unlayered through the drama process. Matthew DeCoursey, too, touched upon Shakespeare, this time in Hong Kong schools. He explored the notion of shame and pride in Chinese culture as children participated in a theatre production. ‘The Right Fighters’ was a play devised by children with different learning needs, directed by Michele Chung, who discussed the theatrical process and strategies that she employed during the course of this production. It was clear from her chapter that theatre is an empowering tool for children in many ways. The book has taken readers through a journey of drama and theatre in different countries. It is noteworthy that the existence of drama is not just prominent in the developed world but is also visible in developing countries and in conflict ridden nations. Shifra Schonmann illustrated her practical work with students in a teacher training programme at the University of Haifa, Israel. She drew upon the merging of art and life in the Israeli context of education. The marginalization of girls in Tanzania was explicitly portrayed by Vicensia Shule in her chapter, in which she described how Tuseme, a theatre project run by the University of Dar es Salaam, could empower both young girls and boys in Tanzanian secondary schools. The contributions for the book have come from a wide range of diverse socioeconomic, political and cultural backgrounds. Yet the collective voices have pointed out the significance of drama and theatre for augmenting the development of children and enriching their lives in a holistic manner. The end of the book projects light and hope for the future, wherein educators, academia, drama practitioners, researchers and political leaders can envision creating more humble, sensitive, creative and humane generations who could create a peaceful world. Theatre when used with children also has tremendous scope to address issues and concerns of children and of society at large. It can be used as a powerful tool for empowerment and transformation. Of the many opportunities I have had to employ theatre in communities, using theatre with male youths in a rural village of Mewat in India was one of the most empowering for the participants. The young men evolved a play based on the concerns and issues faced by the women in their region. The play was performed in local villages and evoked responses towards improving the status of the region’s women. This infused dialogue between the community and political leaders, resulting in addressing and finding solutions to the struggles of local community members. Theatre was thus used as a tool for social reform. The use of drama in classrooms can be challenging for teachers and students as they are co-creators in a process for which the outcome is not predetermined but created together as a team. Co-creation in a drama class is an experience full of content, along with an urge for creation. As students take part in a drama class, they are participants in the process, sharing their thoughts, opinions, voices and ideas in a particular situation. Drama when used as a mode for curricular transaction has tremendous impact on group interaction as students develop an understanding about group dynamics and a variety of relationships; they explore different perspectives and make choices in a particular situation. The process involves critical reflection, collaboration, introspection, decision-making and problem-solving, as children participate together as a group. When children experiment in novel situations, they feel empowered as they find more responsibility to play around with a ‘what if ' situation where nothing is fixed, where the situation is fluid and the onus is on them to construct it in any direction they wish. Children see themselves as adventurers on a path with a willingness to explore as they move along. The process also provides scope for in-depth inquiry on the subject, as well as group discussion as they reflect on their experiences. © 2016 C. Sharma.},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1}
}

@BOOK{Monaco201287,
	author = {Monaco, Camilla and Pontecorvo, Clotilde},
	title = {Explanatory discourse and historical reasoning in children‘s talk: An experience of small group activity},
	year = {2012},
	journal = {Children's Peer Talk: Learning from Each Other},
	pages = {87 - 106},
	doi = {10.1017/CBO9781139084536.008},
	url = {https://www.scopus.com/pages/publications/84923414066?origin=resultslist},
	abstract = {Introduction. Small group work is generally assumed to facilitate “exploratory talk” (Barnes 1976). In this study we hypothesized that it would also facilitate the exploratory development of “historical thinking” in primary school children. Our main aim was to investigate the effect of social and discursive aspects of small group interaction on the development of historical reasoning. As far as teachers’ and educationalists’ intentions are concerned, history teaching should aim, among other things, at developing the skill to give more adequate and articulate explanations for events and actions concerning people and protagonists of the past, capturing them in their space and time settings, within the society and the culture in which they lived. In a word, the aim of history teaching should be to develop the ability to locate phenomena and people within temporal and contextual frameworks. (Girardet 1991: 201, our translation). History teaching should be based on what Girardet defines as “learning to explain historically” (1991). This capacity is grounded outside the school, in children’s everyday efforts to try to explain their own and others’ behavior. Starting at a very young age, children are able to construct explanations concerning their deviant behavior (Pontecorvo and Sterponi 2002): it is rather common to observe how young toddlers, for instance, are able to give good reasons for having refused a requested action (Pontecorvo and Sterponi 2006; Zadunaisky Ehrlich and Blum-Kulka 2010, this volume). Studies on historical reasoning development show that such a skill improves together with cognitive development and with the accumulation of life experiences (Fasulo et al. 1998; Girardet 1991). Within this developmental process, peer interaction plays a decisive role: “explaining is a social activity: one explains something to someone else in order to obtain a change in the audience’s view” (Girardet 1991: 202). If one sees historical reasoning as a socially mediated ability, school is undeniably one of the best settings for its development and learning. In particular, social interaction is one of the more appropriate contexts for stimulating and promoting children’s and youngsters’ explanatory skills (Muller Mirza and Perret-Clermont 2009; Pontecorvo and Arcidiacono 2010; Goldberg, Schwarz and Porat 2011). © Cambridge University Press 2014.},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 3}
}

@ARTICLE{Knudsen2022589,
	author = {Knudsen, Christina Bruun and Hemager, Nicoline and Greve, Aja Neergaard and Lambek, Rikke and Andreassen, Anna Krogh and Veddum, Lotte and Brandt, Julie Marie and Gregersen, Maja and Krantz, Mette Falkenberg and Søndergaard, Anne and Steffensen, Nanna Lawaetz and Birk, Merete and Stadsgaard, Henriette Brockdorff and Ohland, Jessica and Burton, Birgitte Klee and Jepsen, Jens Richardt Møllegaard and Thorup, Anne Amalie Elgaard and Nordentoft, Merete and Mors, Ole and Bliksted, Vibeke Fuglsang},
	title = {Neurocognitive Development in Children at Familial High Risk of Schizophrenia or Bipolar Disorder},
	year = {2022},
	journal = {JAMA Psychiatry},
	volume = {79},
	number = {6},
	pages = {589 - 599},
	doi = {10.1001/jamapsychiatry.2022.0465},
	url = {https://www.scopus.com/pages/publications/85128381064?origin=resultslist},
	abstract = {Importance: Neurocognitive impairments exist in children at familial high risk (FHR) of schizophrenia and bipolar disorder. Studies on preadolescent developmental courses of neurocognition are important to describe shared and distinct neurodevelopmental pathways in these groups. Objective: To assess the development in specific neurocognitive functions from age 7 to 11 years in children at FHR of schizophrenia or bipolar disorder compared with children in a population-based control (PBC) group. Design, Setting, and Participants: The Danish High Risk and Resilience Study is a prospective, longitudinal, cohort study that collected data from January 1, 2013, to January 31, 2016 (phase 1), and from March 1, 2017, to June 30, 2020 (phase 2). Data were collected at 2 university hospitals in Denmark, and participants included 520 children at FHR of schizophrenia or bipolar disorder along with a PBC group matched with the group of children at FHR of schizophrenia by age, sex, and municipality. Exposures: Parental schizophrenia, bipolar disorder, or neither. Main Outcomes and Measures: Neurocognitive functioning was assessed with validated tests of intelligence, processing speed, attention, memory, verbal fluency, and executive functioning. Multilevel mixed-effects linear regression models with maximum likelihood estimation were used to estimate neurocognitive development from age 7 to 11 years. Results: At 4-year follow-up, a total of 451 children (mean [SD] age; 11.9 [0.2] years; 208 girls [46.1%]) underwent neurocognitive testing. There were a total of 170 children at FHR of schizophrenia (mean [SD] age, 12.0 [0.3]; 81 girls [47.7%]), 103 children at FHR of bipolar disorder (mean [SD] age, 11.9 [0.2] years; 45 girls [43.7%]), and 178 children in the PBC group (mean [SD] age, 11.9 [0.2] years; 82 girls [46.1%]). At either age 7 or 11 years or at both assessments, 520 children participated in the neurocognitive assessment and were therefore included in the analyses. When correcting for multiple comparisons, no statistically significant time × group interactions were observed across the 3 groups. Compared with the PBC group at 4-year follow-up, children at FHR of schizophrenia showed significant neurocognitive impairment in 7 of 24 neurocognitive measures (29.2%; Cohen d range, 0.29-0.37). Compared with children at FHR of bipolar disorder, children at FHR of schizophrenia had significant neurocognitive impairment in 5 of 24 measures (20.8%; Cohen d range, 0.29-0.38). Children at FHR of bipolar disorder and those in the PBC group did not differ significantly. Conclusions and Relevance: In this cohort study, findings suggest that neurocognitive maturation was comparable across groups of children at FHR of schizophrenia or bipolar disorder compared with PBCs from age 7 to 11 years. Compared with the PBC group, children at FHR of schizophrenia demonstrated widespread, stable, neurocognitive impairments during this period, whereas children at FHR of bipolar disorder showed no neurocognitive impairments, which may indicate distinct neurodevelopmental pathways in children at FHR of schizophrenia and bipolar disorder.. © 2022 American Medical Association. All rights reserved.},
	keywords = {Bipolar Disorder; Child; Cohort Studies; Executive Function; Female; Humans; Neuropsychological Tests; Prospective Studies; Schizophrenia; Article; attention; bipolar disorder; child; children global assessment scale; clinical assessment; cognitive development; cohort analysis; controlled study; executive function; female; follow up; group dynamics; high risk patient; human; intelligence; longitudinal study; major clinical study; male; memory; phase 1 clinical trial; phase 2 clinical trial; processing speed; prospective study; Rey Osterrieth complex figure test; schizophrenia; school child; speech; trail making test; neuropsychological test; psychology},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 21; All Open Access; Bronze Open Access; Green Open Access}
}

@ARTICLE{Sargénius2023,
	author = {Sargénius, Hanna L. and Andersson, Stein and Haugen, Ingvild and Hypher, Ruth and Brandt, Anne Elisabeth and Finnanger, Torun G. and Rø, Torstein B. and Risnes, Kari and Stubberud, Jan},
	title = {Cognitive rehabilitation in paediatric acquired brain injury—A 2-year follow-up of a randomised controlled trial},
	year = {2023},
	journal = {Frontiers in Neurology},
	volume = {14},
	pages = {},
	doi = {10.3389/fneur.2023.1173480},
	url = {https://www.scopus.com/pages/publications/85162022136?origin=resultslist},
	abstract = {Background: Goal management training (GMT), a metacognitive rehabilitation method that has been demonstrated to improve executive function (EF) in adults with acquired brain injury (ABI), could potentially be effective for children in the chronic phase of ABI. In a previously published randomised controlled trial (RCT), the efficacy of a paediatric adaptation of GMT (pGMT) compared to a psychoeducative control intervention (paediatric Brain Health Workshop, pBHW) was investigated. Comparable improvements in EF in both groups were found at 6-month follow-up. However, a specific effect of pGMT could not be conclusively proven. The present study reports 2-year follow-up data (T4; T1: baseline, T2: post-intervention, T3: 6-month follow-up, and T4: 2-year follow-up) from this original RCT. Methods: A total of 38 children and adolescents and also their parents completed questionnaires tapping into daily life EF. Explorative analyses were conducted comparing the 2-year follow-up data (T4) with the baseline (T1) and 6-month follow-up data (T3) for T4-participants in the two intervention groups (pGMT; n = 21, pBHW; n = 17), and we also assessed T4-participants vs. non-responders (n = 38) in the RCT. Primary outcome measures were the Behavioural Regulation Index (BRI) and the Metacognition Index (MI) derived from the Behaviour Rating Inventory of Executive Function (BRIEF) parent report. Results: No difference between intervention groups was found (BRI, F = 2.25, p = 0.143, MI, F = 1.6, p = 0.213), and no time<sup>*</sup>group interaction (BRI, F = 0.07, p = 0.976, MI, F = 0.137, p = 0.937) could be seen at the 2-year follow-up. Nevertheless, both pGMT and the pBHW groups improved daily EF as measured by parental reports over time from the baseline to T4 (p = 0.034). T4 participants and non-responders shared similar baseline characteristics. Conclusion: Our results extend the findings from the 6-month follow-up previously published. Both pGMT and pBHW groups sustained their improvements in daily life EFs from the baseline, but additional effectiveness of pGMT relative to pBHW was not found. Copyright © 2023 Sargénius, Andersson, Haugen, Hypher, Brandt, Finnanger, Rø, Risnes and Stubberud.},
	author_keywords = {acquired brain injury; executive function; goal management training; paediatric; randomised controlled trial (RCT)},
	keywords = {acquired brain injury; adaptation; adolescent; Article; attention deficit hyperactivity disorder; behavior rating inventory of executive function; brain injury; brain tumor; cerebrovascular accident; child; clinical article; cognition; cognitive rehabilitation; educational status; encephalitis; executive function; fatigue; female; follow up; high school; human; hypoxia; intelligence; Likert scale; male; maximum likelihood method; metacognition; outcome assessment; Pediatric Quality of Life Inventory; primary education; processing speed; psychoeducation; questionnaire; randomization; rank sum test; school child; self report; social psychology; sociodemographics; training; traumatic brain injury; university; working memory},
	type = {Article},
	publication_stage = {Final},
