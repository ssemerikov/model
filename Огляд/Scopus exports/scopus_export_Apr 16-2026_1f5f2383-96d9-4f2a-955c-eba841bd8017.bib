@ARTICLE{Barnes-Story2025,
	author = {Barnes-Story, Adrienne E. and Robinette, Jennie J. and Wawire, Brenda A. and Jere, Bubire},
	title = {Teaching and managing large classes: A global scoping review of methods with primary and secondary learners},
	year = {2025},
	journal = {International Journal of Educational Development},
	volume = {119},
	pages = {},
	doi = {10.1016/j.ijedudev.2025.103450},
	url = {https://www.scopus.com/pages/publications/105022169077?origin=resultslist},
	abstract = {Access to a free and compulsory primary school education has caused access shock to many education systems. Increased enrollment compounded by rapid population growth in low- and middle-income countries (LMICs) has required teachers to face educating an exploding population of learners and increasingly large class sizes. This scoping review examines the methods that teachers use to manage, instruct, and assess learners in the overcrowded conditions. The literature highlights the need for teachers to utilize active and cooperative learning strategies to deliver instruction that differentiates for learner needs and varies in format to keep learners engaged. Group work is particularly emphasized as a mechanism to handle activities in classrooms with more than 100 learners. Effective classroom management might be achieved when teachers build rapport with learners and establish a safe and positive classroom community with clear routines, procedures, expectations, and consequences. Teachers are advised to simplify assessment processes, integrating more group assessments and fewer written exercises requiring individual grading – although the challenges with assessment requirements are noted. Of most consequence is that nearly all findings in the literature are anecdotal or observational in nature, and the authors were unable to locate a single study that empirically tested the effectiveness of any large class pedagogy. © 2025 Elsevier Ltd},
	author_keywords = {Large class pedagogy; LMICs; Overcrowded classrooms; Primary school instruction; Teaching large classes},
	keywords = {educational development; literature review; population dynamics; primary education; secondary education; strategic approach; teaching},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Green Open Access}
}

