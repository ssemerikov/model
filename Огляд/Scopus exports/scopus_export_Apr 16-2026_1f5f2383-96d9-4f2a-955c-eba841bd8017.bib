	title = {OPTIMIZING ENGLISH ACHIEVEMENT: EXPLORING THE IMPACT, PERCEPTIONS, AND CHALLENGES OF GROUP COOPERATIVE LEARNING AMONG RURAL PRIMARY SCHOOL STUDENTS IN CHINA},
	year = {2025},
	journal = {Journal of the Balkan Tribological Association},
	volume = {31},
	number = {1},
	pages = {117 - 130},
	url = {https://www.scopus.com/pages/publications/105001106368?origin=resultslist},
	abstract = {The purpose of this research was to explore the effects of cooperative learning on the English achievement of rural primary school students in China. Using a hybrid approach, the study combines quasi-experiments, surveys, and semi-structured interviews to comprehensively explore student perceptions, benefits, and challenges of cooperative learning. The survey showed that the vast majority had positive attitudes towards cooperative learning, with students citing improved academic performance and a good overall experience. The meeting also identified challenges such as consensus building and effective communication. The integration of semi-structured interviews provides qualitative insights that enrich the understanding of the dynamic complexity of cooperative learning. The findings highlight the need for targeted interventions to optimize the group collaborative learning experience. Recommendations include professional development for educators, curriculum integration, diversification of cooperative strategies, mentoring programs, continuous feedback mechanisms, and long-term impact assessments. The existing literature benefits from this research because the research provides a nuanced perspective on the multifaceted nature of group cooperative learning in rural primary schools. The insights gained can inform educators, policymakers, and researchers to enhance the implementation of collaborative learning strategies that contribute to the overall academic development of students. © 2025, Scibulcom Ltd.. All rights reserved.},
	author_keywords = {benefits; challenges; cooperative learning; english achievement; perceptions; rural primary schools},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1}
}

@ARTICLE{Barrenetxea-García2025,
	author = {Barrenetxea-García, Josu and Ortuondo Bárcena, Jon and Méndez-Giménez, Antonio},
	title = {Effects of a unit of circus activities through a hybridization of cooperative learning and self-made material: a students, teachers and parents combined perspective},
	year = {2025},
	journal = {Physical Education and Sport Pedagogy},
	pages = {},
	doi = {10.1080/17408989.2025.2470308},
	url = {https://www.scopus.com/pages/publications/86000009356?origin=resultslist},
	abstract = {Background: Interest in circus activities (CA) has increased in recent years within the educational field, particularly among Physical Education (PE) teachers. These CAs are characterized by being inclusive and motivating, and they encourage the development of motor and social skills among students. In addition, scientific evidence is emerging that demonstrates the benefits of hybridizing different pedagogical models, such as cooperative learning (CL) and self-made material (SMM), in the teaching of PE. The objectives of this research were twofold: (a) to examine the affective, attitudinal, and social impact of implementing a CA unit in which the CL and SMM pedagogical models were hybridized in PE, and (b) to analyze the physical and motivational impact of this intervention from the perspective of the three agents involved: students, teachers, and parents. Material and method: A total of 143 educational agents from a private school in the Basque Country (Spain) participated in this qualitative study, undergoing semi-structured interviews: 88 students from 1st to 6<sup>th</sup> grade of Primary School (M = 9.49 ± 1.66 years), 16 students from 1st grade of Secondary School (M = 12.38 ± 0.50 years), 11 Primary School teachers (M = 33.27 ± 5.12 years), and 28 parents (M = 45.79 ± 5.56 years). The unit lasted ten weeks, culminated in the creation of a circus act involving all the Primary School students in PE. Data analysis by categories was based on data reduction, descriptive analysis, and interpretation. Results: The authors constructed four dimensions shared by the educational agents: Self-made materials, Psychological effects, Physical effects, and Obstacles and facilitators. Additionally, there were two dimensions exclusive to teachers and parents: Knowledge of the program and Socialization. The CA unit was very satisfactory for the agents involved, and the results derived from the interviews with the participants were aligned with Self-Determination Theory, as well as with the positive effects corroborated by previous research on the implementation of the pedagogical models of CL and SMM. The intervention was shown to be effective in increasing satisfaction, CA learning, active participation, motivation, social interaction, and sustainability awareness among the participating students, as well as in enhancing collective community awareness. Conclusion: The results corroborate the hybridization of CL and SMM models to enhance the teaching of CA and promote the holistic development of students within PE. © 2025 Association for Physical Education.},
	author_keywords = {circus; Pedagogical models; self-determination; sustainability},
	type = {Article},
	publication_stage = {Article in press},
	source = {Scopus},
	note = {Cited by: 1}
}

@ARTICLE{Segundo-Marcos2025499,
	author = {Segundo-Marcos, Rafael and Merchán Carrillo, Ana and López Fernández, Verónica and Daza González, María Teresa},
	title = {Creative Thinking Skills and Executive Functions in Preadolescent Children},
