	source = {Scopus},
	note = {Cited by: 3; All Open Access; Hybrid Gold Open Access}
}

@ARTICLE{Talkhan2025,
	author = {Talkhan, Eman and Alhubaidah, Shahad and Muthanna, Aisha and Qadhi, Saba},
	title = {The effect of cooperative learning toward mathematics achievement of primary students: A systematic review using meta-analysis},
	year = {2025},
	journal = {Social Sciences and Humanities Open},
	volume = {12},
	pages = {},
	doi = {10.1016/j.ssaho.2025.102247},
	url = {https://www.scopus.com/pages/publications/105023664876?origin=resultslist},
	abstract = {Mathematics is a core subject in primary education and a critical foundation for lifelong learning, yet many learners struggle to achieve the expected proficiency levels. Cooperative learning (CL) has been recognized as an effective instructional strategy; however, evidence on its impact on mathematics achievement particularly in the primary stage remains fragmented and inconclusive. This meta-analysis addresses this gap by synthesizing results from 30 empirical studies published between January 2019 and September 2023, retrieved from Web of Science, Scopus, ERIC, and Google Scholar. Eligible studies met predefined inclusion criteria and were analyzed using a random-effects model. The pooled effect size (Hedges' g) = 0.71 (95 % CI = 0.60–0.82, Z = 12.56, p < .001), indicating a moderate-to-large positive effect of CL on students' mathematics achievement. Heterogeneity was significant (Q = 152.41, df = 29, p < .001, I<sup>2</sup> = 80.97 %), prompting moderator analyses. Results revealed strong positive effects of cooperative learning for primary school students (overall g = 0.79), with moderate-to-large variations across specific models. Among the most frequently implemented approaches, Jigsaw and STAD showed relatively higher effects, while TSTS and TPS produced moderate but consistent gains. Moreover, studies integrating technology within cooperative learning frameworks reported slightly enhanced outcomes, suggesting that digital tools can reinforce collaboration and engagement. No significant publication bias was detected (Egger's p = .138), and sensitivity analyses confirmed the robustness of findings. These results highlight the substantial potential of CL particularly in primary education and culturally supportive contexts to enhance mathematics learning. The study suggests that structured cooperative learning strategies such as Jigsaw and STAD hold strong potential for effective curriculum integration. It also highlights the value of incorporating technology to support student interaction and recommends conducting further large-scale research in diverse educational contexts to expand the global evidence base. Copyright © 2025. Published by Elsevier Ltd.},
	author_keywords = {Cooperative learning; Mathematics achievement; Meta-analysis; Primary school; Systematic review},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access}
}

@ARTICLE{Versfeld2026,
	author = {Versfeld, Jessica and Ferreira, Ronél and Botha, Karien},
	title = {School communities’ expectations of a school-based health promotion intervention in South Africa},
	year = {2026},
	journal = {Health Education Journal},
	pages = {},
	doi = {10.1177/00178969261430604},
	url = {https://www.scopus.com/pages/publications/105033388961?origin=resultslist},
	abstract = {Background: School-based health promotion interventions in resource-constrained settings must align with curriculum requirements and the local context to be sustainable and effective. In South Africa, there is a need to integrate support for nutrition, psychosocial well-being, and environmental sustainability within everyday teaching and learning. Aim: This study explored the expectations of school communities regarding Wellness in Lifestyle, Intake, Fitness, and Environment (Win-LIFE), a school-based health promotion intervention designed for use in resource-constrained South African contexts. Methods: A qualitative, multiple-case design was employed using Participatory Reflection and Action (PRA) methodology to co-develop and adapt the intervention with teachers, parents, learners, and institutional stakeholders. Data were generated through document reviews, semi-structured interviews, focus groups, workshops, and observations conducted in three primary schools. Reflexive thematic analysis was used to identify patterns in stakeholder expectations. Results: Five key expectations were evident across stakeholders: namely, that the intervention should be educational and practical; that it should be aligned with the South African Curriculum and Assessment Policy Statement for Grades 4–6; that it should be grounded in cooperative learning; that it should be engaging and enjoyable for learners; and that it should be inclusive of parental involvement. Conclusion: The findings from this study highlight the importance of contextual alignment, meaningful stakeholder participation, and curriculum integration in the design of sustainable school-based health promotion interventions. The study demonstrates how schools can function as inclusive hubs for promoting health and well-being in marginalised communities. © The Author(s) 2026. This article is distributed under the terms of the Creative Commons Attribution 4.0 License (https://creativecommons.org/licenses/by/4.0/) which permits any use, reproduction and distribution of the work without further permission provided the original work is attributed as specified on the SAGE and Open Access pages (https://us.sagepub.com/en-us/nam/open-access-at-sage).},
	author_keywords = {Curriculum enrichment; parental involvement; participatory methodology; resource-constrained community; school-based health promotion},
	type = {Article},
	publication_stage = {Article in press},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Hybrid Gold Open Access}
}

@ARTICLE{Keramati2026177,
	author = {Keramati, Mohammad Reza and Ansarizadeh, Fahimeh and Keramati, Ali},
	title = {Developing future leaders: practicing reflective leadership skills in Iranian primary schools within a cooperative learning environment},
	year = {2026},
	journal = {Reflective Practice},
	volume = {27},
	number = {2},
	pages = {177 - 190},
	doi = {10.1080/14623943.2025.2541423},
	url = {https://www.scopus.com/pages/publications/105012423065?origin=resultslist},
	abstract = {The literature review indicates that the development of leadership skills through teaching and learning approaches has received less attention. In this study, we aimed to explore how leadership skills of students are cultivated in a cooperative learning (CL) environment. Our investigation extended beyond a qualitative synthesis; we also employed the method of focus groups to enhance, refine, and expand the data, resulting in a more precise and comprehensive model. The findings from two qualitative studies have inspired the development of a new questionnaire. Through confirmatory factor analysis, we aim to validate the questionnaire scores and assess the model fit. Results demonstrated that the model requires necessary fit. The findings revealed that positive and reciprocal interdependence enhance listening skills, respect for others, cooperation, relationship, acceptability, and empathy as key elements of CL. Responsibility, as the second basic element, improves self-confidence, self-esteem, respecting the rights of others, and responsibility. Interpersonal skills play a role in developing interaction and relationship competencies, while problem-solving, conflict resolution, guidance, and group awareness enhance students’ abilities. Additionally, the results highlighted that interaction, as the fourth element of CL, enhances relationship and problem-solving skills. These results can motivate educators to adopt CL approaches in classrooms and encourage educational policymakers to prioritize this approach when designing teacher training curricula. © 2025 Informa UK Limited, trading as Taylor & Francis Group.},
	author_keywords = {Cooperative learning; focus groups; meta-synthesis; primary schools; reflective leadership skills; structural equation modelling},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Muchie2025,
