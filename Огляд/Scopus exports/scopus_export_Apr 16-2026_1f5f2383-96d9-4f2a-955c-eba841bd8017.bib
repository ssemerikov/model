	pages = {},
	doi = {10.1186/s40561-025-00391-4},
	url = {https://www.scopus.com/pages/publications/105013344951?origin=resultslist},
	abstract = {Education has an immense impact on the society. It trains the human mind to think and take the right action and decision. The purpose of this study was to understand the Teachers and Students perceptions, practices, and challenges of active learning Strategy Utilization in primary schools. The main purpose of this study was to assess the level of implementation of active learning and identify the major challenges that affect its proper implementation in government-selected primary schools. To achieve this purpose, the researcher used a Descriptive survey design and applied both quantitative and qualitative methods. This study conducted in eight primary schools, the research participants for this study were 200 Grde 7th and Grade 8th Students, 180 Teachers, 8 principals and 8. Teachers and student were selected by simple random sampling by lottery methods, principals, and supervisors selected by purposive sampling. To gather data, questionnaires, and interviews were employed. Quantitative data were analyzed using descriptive statistical tools while qualitative data were analyzed through the use of summaries and themes. The outcomes of the study suggested that the level of implementation of active learning methodology was low as classes were more teacher-dominated. The most dominant methods of teaching employed were lecture and direct instruction. The finding indicated that the factors that challenge the implementation of active learning were mainly administrative, curriculum-related factors, scarcity of material and financial resources were the constraints to implement active learning strategy in primary schools in this study area. © The Author(s) 2025.},
	author_keywords = {Active learning strategy; Cooperative learning; Teacher center teaching strategy},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 2; All Open Access; Gold Open Access; Green Open Access}
}

@ARTICLE{Leasa2025318,
	author = {Leasa, Marleny and Seriholo, Syane and Papilaya, Pamella Mercy and Batlolona, John Rafafy},
	title = {Research-based learning: creative thinking skills of primary school pupils in science learning},
