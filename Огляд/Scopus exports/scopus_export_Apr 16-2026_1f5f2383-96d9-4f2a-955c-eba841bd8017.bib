@ARTICLE{Andreatti2026,
	author = {Andreatti, Giovanna and Morselli, Daniele},
	title = {Cooperative or Game-Based Learning? Fostering Financial Literacy for Sustainable Citizenship Through Two Contrasting Implementations in Primary Education},
	year = {2026},
	journal = {Sustainability (Switzerland)},
	volume = {18},
	number = {3},
	pages = {},
	doi = {10.3390/su18031545},
	url = {https://www.scopus.com/pages/publications/105030023372?origin=resultslist},
	abstract = {Financial education is critical for fostering inclusive, resilient societies by reducing inequalities and promoting sustainable development. Despite growing interest, there is a notable gap in research on effective pedagogical approaches for financial literacy in primary education. Early intervention is essential to shape financially literate, active citizens capable of contributing to sustainable communities. This study addresses this gap by comparing the effectiveness of two distinct implementation packages involving active pedagogies—cooperative learning (CL) with high autonomy and stable groups, and game-based learning (GBL) featuring stronger teacher orchestration and dynamic grouping—in enhancing financial literacy among primary school pupils. Using a multiple case study design, two fifth-grade classes in Northern Italy participated in six 2 h financial education sessions, each employing a different instructional implementation package. Quantitative data from pre- and post-tests revealed significant improvements in financial literacy in both groups, confirmed by Wilcoxon signed-rank tests, with CL-based implementation showing a larger observed effect size (Hedges’g = 1.84) than GBL-based implementation (g = 1.20). Qualitative analysis of focus groups showed that CL-based implementation, characterized by high autonomy and group stability, fostered deeper learning through collaboration, shared responsibility, and relational skills vital for social sustainability. In contrast, GBL-based implementation, with structured teacher facilitation, promoted context-specific knowledge and relied more on extrinsic motivation and competition. These findings suggest that the observed benefits may be associated with the combined features of the cooperative learning-based implementation package, particularly high autonomy and stable group structures, which appear to support more socially embedded financial literacy. They also highlight both the potential and the limitations of game-based approaches. The study offers evidence-based insights for designing effective financial education programs that support both cognitive and social competencies in primary education. © 2026 by the authors.},
	author_keywords = {cooperative learning; economic sustainability; evidence-based research; financial education; game-based learning; primary education},
	keywords = {Italy; autonomy; citizenship; cooperative sector; education; financial system; literacy; machine learning; policy implementation; research work},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access; Green Open Access}
}

@ARTICLE{Cavaion2025127,
	author = {Cavaion, Irina Moira},
	title = {Reciprocity in Language Learning: From Tandem Language and Culture Learning to Contact-Based-Language-Learning-and-Teaching (CoBLaLT)},
	year = {2025},
	journal = {Multilingual Education},
	volume = {49},
	pages = {127 - 157},
	doi = {10.1007/978-3-031-76043-3_7},
	url = {https://www.scopus.com/pages/publications/105001565298?origin=resultslist},
	abstract = {Reciprocal learning is a practice that has been indefinitely present in language teaching and learning but undervalued in theoretical studies of applied linguistics and educational linguistics. It was developed in the late 1980s by Erik Hawkins (Hawkins, E. W. Modern languages in the curriculum (pp. 190–195). Cambridge University Press, 1981) and Vivian Cook (Modern English Teacher, 16(3/4):48–53, 1989) and has remained a scientifically unexplored concept, although it could be a great help to didactics for language teaching and learning, especially for teenagers, a category of learners eager for authentic relationships. On the other hand, social and developmental psychologists, anthropologists, and political scientists invite us to consider the basic psychological mechanism of reciprocity, possibly rooted in evolution, and its importance for health and well-being (Buunk and Schaufeli, European Review of Social Psychology, 10(1):259–291, 1999). Our proposal is a pedagogy (the Contact-Based Language Learning and Teaching Method, Cavaion, I. M. Let’s contact! An introductory study to CoBLaLT. Univerzitetna založba Annales, 2016; Cavaion, I. M. Guida alla Didattica del Contatto [CoBLaLT teachers’ guide]. Znanstveno-raziskovalno središče Koper, Annales ZRS, 2019; 2020, 2021) based on the belief that reciprocity needs to be valued more, i.e., we as teachers and researchers of applied linguistics need to provide and foster a sense of mutual exchange, personal enrichment, and social, human growth in language learning. The consequence of such an approach is in a reduction of authority/power (language status), a shift and orientation of focus from communication as information exchange to communication for relationship building, tasks to be accomplished together in a collaborative and cooperative learning process, complicity and sharing of common interests, i.e., language focused on a lexicon useful for young people, usually excluded from textbooks. At the moment the methodology is shifting from the concept of contact as a social phenomenon (theories of contact between groups) to a conceptualization of contact as a more complex interpersonal encounter, in which we refer to responsibility, care, otherness and reciprocity as core principles and goals of language learning, very inspired by K. Kramsch’s thoughts (2019). Our scientific experience has developed in the last ten years in the context of cross-border contact of mainstream primary schools settled in the Italian and Slovenian border area, but in this paper, we argue in favour of the possibility, if not the necessity, of incorporating the principle of reciprocity into any kind of language teaching and learning in an educational and training context such as school. © The Author(s), under exclusive license to Springer Nature Switzerland AG 2025.},
	author_keywords = {Affective language learning; Contact-based-language-learning-and-teaching; Reciprocal language learning; Reciprocity; Tandem language learning},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

