@ARTICLE{Karampa2018226,
	author = {Karampa, Vasiliki and Paraskeva, Fotini},
	title = {A motivational design of a flipped classroom on collaborative programming and STEAM},
	year = {2018},
	journal = {Communications in Computer and Information Science},
	volume = {870},
	pages = {226 - 238},
	doi = {10.1007/978-3-319-95522-3_19},
	url = {https://www.scopus.com/pages/publications/85051919688?origin=resultslist},
	abstract = {The purpose of this study was to design a blended learning environment, specifically a flipped classroom in order to provide capabilities for motivation to primary school students, to familiarize them with programming principles and encourage them to get involved with the STEAM (Science, Technology, Engineering, Arts, Mathematics) fields. The blended learning environment provides on-line distance learning programming activities integrated into Moodle through which asynchronous collaboration and problem solving skills are cultivated. It also provides face-to-face active learning through STEAM programming activities. The instructional design is based on the ARCS motivational model, for each of its key components (Attention - Relevance - Confidence - Satisfaction) different strategies and techniques were incorporated and combined with collaborative learning techniques, using various technological means. The study investigates mainly the impact of this design on the terms of: (a) motivation, (b) collaboration and (c) computational thinking of the students. The findings tentatively indicate that the instructional design of the blended environment is capable to empower motivation and enhance students’ collaborative and computational thinking skills. However, a further research is required to confirm the proposed conceptual framework. © Springer International Publishing AG, part of Springer Nature 2018.},
	author_keywords = {ARCS model; Collaborative learning (CL); Flipped classroom; Moodle; Motivation; STEAM},
	keywords = {Computer aided instruction; E-learning; Education computing; Engineering education; Motivation; Problem solving; Steam; ARCS model; Asynchronous collaboration; Blended learning environments; Collaborative learning; Collaborative programming; Computational thinkings; Flipped classrooms; Moodle; Students},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 9}
}

@ARTICLE{Li2022,
	author = {Li, Jie and Luo, Heng and Zhao, Leilei and Zhu, Min and Ma, Lin and Liao, Xiaofang},
	title = {Promoting STEAM Education in Primary School through Cooperative Teaching: A Design-Based Research Study},
	year = {2022},
	journal = {Sustainability (Switzerland)},
	volume = {14},
	number = {16},
	pages = {},
	doi = {10.3390/su141610333},
	url = {https://www.scopus.com/pages/publications/85137693412?origin=resultslist},
	abstract = {The COVID-19 pandemic has highlighted the importance of students’ information literacy, computer skills, and research competencies for self-regulated learning and problem solving. STEAM education, with interdisciplinary knowledge building and higher-order thinking development as its main purpose, is considered essential for students’ sustainable development in the post-pandemic era. However, STEAM education in China’s K-12 schools is facing several problems, such as insufficient qualified teachers, unsustainable development, and difficulty in achieving meaningful discipline integration. To address these problems, this study proposes an innovative STEAM education model supported by cooperative teaching and theories of project-based learning and collaborative learning. After two iterations of design, evaluation, and revision, the proposed STEAM education model and a set of instructional design principles were validated. The resulting model features a multi-teacher cooperative strategy, detailed and diverse scaffolding, familiar themes for students, the integration of STEAM education into formal curricula, and extended instruction hours. The study results suggest that cooperative teaching can facilitate meaningful discipline integration and can alleviate the STEAM faculty shortage. This study produced five proven instructional design principles for conducting STEAM education supported by cooperative teaching in primary schools. © 2022 by the authors.},
	author_keywords = {China; cooperative teaching; design-based research; STEAM; STEM},
	keywords = {China; COVID-19},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 55; All Open Access; Gold Open Access; Green Open Access}
}

@ARTICLE{Vicente20201,
	author = {Vicente, Francisco Ruiz and Llinares, Alberto Zapatera and Sánchez, Nicolás Montés},
	title = {“Sustainable City”: A Steam Project Using Robotics to Bring the City of the Future to Primary Education Students},
	year = {2020},
	journal = {Sustainability (Switzerland)},
	volume = {12},
	number = {22},
	pages = {1 - 21},
	doi = {10.3390/su12229696},
	url = {https://www.scopus.com/pages/publications/85096329835?origin=resultslist},
	abstract = {This article presents a STEAM project, “Sustainable City”, based on educational robotics whose objective is to bring the problems of climate change closer to primary school students. The participants were 30 students (aged 10–11) from 5th year of Primary Education and the project consisted of 14 sessions in which different active methodologies such as project-based learning, collaborative learning and the flipped classroom were carried out. A pre-test and a post-test were carried out and the results were better in the post-test, which indicates that the students improved their skills and increased their motivation. As a conclusion, this STEAM project, which is adapted to the Spanish LOMCE curriculum, can be a reference for other teachers to bring their students closer to the problem of environmental change through educational robotics and the use of active methodologies. © 2020 by the authors. Licensee MDPI, Basel, Switzerland.},
	author_keywords = {Active methodologies; Climate change; Educational robotics; STEAM project; Sustainable city},
	keywords = {climate change; curriculum; detection method; education; methodology; student; teaching; urban area},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 37; All Open Access; Gold Open Access; Green Open Access}
}

@CONFERENCE{Dudysheva202554,
	author = {Dudysheva, Elena V. and Vakalova, Valeria A. and Veryaev, Anatoly A.},
	title = {Educational Practice of Interaction with Collaborative Robots in Hybrid Robotic Environments on the Boundary Objects Concept},
	year = {2025},
	journal = {Proceedings - 2025 5th International Conference on Technology Enhanced Learning in Higher Education, TELE 2025},
	pages = {54 - 59},
	doi = {10.1109/TELE66816.2025.11212093},
	url = {https://www.scopus.com/pages/publications/105023821199?origin=resultslist},
	abstract = {The paper explores the use of collaborative robots (co-robots) in hybrid educational environments through the conceptual framework of boundary objects and boundary crossing. The study aimed to theoretically substantiate and empirically validate the applicability of this framework for organizing interactions between students and collaborative robots in educational settings. Conducted at the Technopark of Altai State Pedagogical University, the study involved primary school learners completing three practice-oriented tasks - hazard removal, structural assembly, and ecological cleanup - within pre-configured educational robotic environments. Pedagogical observation and process documentation were used to assess outcomes. The findings demonstrated successful acquisition of basic programming and interaction skills with robotic agents, reflected in learners' diverse problem-solving strategies, debugging abilities, and high emotional engagement. Analysis revealed that hybrid robotic environments establish a unique interaction system integrating four actor categories: learners, teachers (including pre-service teachers), laboratory technicians, and collaborative robots. These systems function through interconnected boundary objects, including physical and digital artifacts, software repositories, and educational tasks as 'ideal-type' models of real-world situations. The study contributes to the theory and practice of pedagogical education by proposing a scalable model for developing future-oriented digital competencies essential in rapidly evolving socio-technical contexts. © 2025 IEEE.},
	author_keywords = {boundary objects; collaborative robots; digital skills; hybrid educational environments; STEAM education},
	keywords = {BASIC (programming language); Collaborative learning; E-learning; Education computing; Educational robots; Problem solving; Robot programming; Robotic assembly; Students; Teaching; Boundary crossing; Boundary objects; Collaborative robots; Conceptual frameworks; Digital skills; Educational environment; Educational settings; Hybrid educational environment; Robotic environments; STEAM education; Collaborative robots},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Lupión-Cobos2023454,
	author = {Lupión-Cobos, Teresa and Crespo-Gómez, José Ignacio and García-Ruiz, Cristina},
	title = {CHALLENGES AND OPPORTUNITIES TO TEACHING INQUIRY APPROACHES BY STE(A)M PROJECTS IN THE PRIMARY EDUCATION CLASSROOM},
	year = {2023},
	journal = {Journal of Baltic Science Education},
	volume = {22},
	number = {3},
	pages = {454 - 469},
	doi = {10.33225/jbse/23.22.454},
	url = {https://www.scopus.com/pages/publications/85163633428?origin=resultslist},
	abstract = {This study analyses the teachers’ perceptions of their capacity for designing and developing STE(A)M projects in a professional development programme (PD) conducted through a collaborative educational research project carried out between the University and the centres by the IndagaSTEAM Escuela project. Incorporating STEAM education in the classroom poses various challenges to teachers, among other aspects, associated with conceptualising, designing and applying the curricular integration of STE(A)M subjects, requiring training programs updates for this purpose. Hence, the design developed promotes applying an inquiry-based approach and adapting the integrative STE(A)M curriculum in the Primary Education classroom. Challenges and opportunities of the teachers’ involvement have been analysed as a case study undertaken longitudinally between 2019 and 2022. Data have been compiled from a varied typology (rubrics evaluation, ad hoc interviews and questionnaires, using the Likert scale), which give an account of the global perception these educators have, on the one hand, of STE(A) M education and the inquiry approach and, on the other hand, of the collaborative learning scenario from the framework used. © 2023, Scientia Socialis Ltd. All rights reserved.},
	author_keywords = {active learning; primary school teacher; teacher skills; teaching fundamental sciences},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 8; All Open Access; Gold Open Access; Green Open Access}
}

