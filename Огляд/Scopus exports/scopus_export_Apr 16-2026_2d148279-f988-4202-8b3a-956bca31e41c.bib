@ARTICLE{Truong2026,
	author = {Truong, Thang Dinh and Dinh, Hong-Van Thi and Ha, Xuan V. and Pham, Kien The and Nguyen, Tram-Anh Thi and Nguyen, Dung Viet},
	title = {Vietnamese Primary Teachers' Autonomy in the Context of Educational Reform},
