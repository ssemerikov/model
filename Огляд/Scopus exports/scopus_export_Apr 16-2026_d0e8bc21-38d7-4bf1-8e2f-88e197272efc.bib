@CONFERENCE{Wildermuth2022,
	author = {Wildermuth, Gemma L.},
	title = {Manuscript USING INQUIRY-BASED LEARNING AND ROLE MODELLING AS A MOTIVATOR FOR INCREASING THE PARTICIPATION OF GIRLS IN SPACE SCIENCE},
	year = {2022},
