@ARTICLE{Tegegne2025,
	author = {Tegegne, Wossen Ayalew and Bizuneh, Shambel Molla and Negasi, Reda Dargie},
	title = {Exploring the promises and classroom realities of constructivist learning at upper primary school in Ethiopia},
	year = {2025},
	journal = {Discover Education},
	volume = {4},
	number = {1},
	pages = {},
	doi = {10.1007/s44217-025-00967-9},
	url = {https://www.scopus.com/pages/publications/105023052942?origin=resultslist},
	abstract = {This qualitative case study investigates the extent to which constructivist learning principles are implemented in actual classroom practices in Ethiopia. Grounded in the theoretical frameworks of Piaget and Vygotsky, the study examines the alignment between national education policies, curriculum frameworks, and textbooks, and how these are reflected in classroom instruction in Science, Mathematics, and English. Data were collected through classroom observations, unstructured interviews with nine teachers, and document analysis of national policies and curriculum materials. Findings revealed a significant disconnect between policy aspirations and teaching practices. While official frameworks advocate for active, student-centered, and inquiry-based learning, classroom instruction remains predominantly teacher-centered, with limited evidence of collaborative learning, reflective thinking, or real-world application. Large class size, insufficient instructional materials, content-time in-balance, and a lack of practical teacher training in constructivist pedagogy were found as constraining factors. The study underscores the need for sustained professional development programs, curriculum streamlining, and systemic support to enable effective implementation of constructivist approaches in resource-constrained school environments. These findings contribute to the discourse on educational reform in developing countries and offer actionable insights for policymakers, curriculum designers, and teacher educators committed to enhancing authentic and constructive teaching and learning quality. © The Author(s) 2025.},
	author_keywords = {Case study; Constructive classrooms; Constructivist approach; Curriculum-policy alignment; Ethiopian education; Primary school; Teacher training},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access; Green Open Access}
}

@ARTICLE{Erceg2025,
	author = {Erceg, Nataša and Alajbeg, Anna},
	title = {Between Tradition and Reform: The Attitudes of Croatian Preservice Primary School Teachers Towards Science Teaching and Their Views on Science},
	year = {2025},
